# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auth.js / NextAuth ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# In production, set AUTH_URL to your canonical URL (e.g. https://app.example.com).
# Auth.js uses this to build callback URLs when behind a proxy.
AUTH_URL=http://localhost:3000

# ─── Google OAuth (sign-in + Gmail compose) ───────────────────────────────────
# Add redirect URI http://localhost:3000/api/auth/callback/google in Google Cloud
# Enable the Gmail API and add scope https://www.googleapis.com/auth/gmail.compose
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database (Postgres; Railway provides DATABASE_URL automatically) ─────────
DATABASE_URL=postgres://user:password@localhost:5432/ff_outreach
# Set to "false" to disable SSL for a local Postgres without certs. Defaults to on.
DATABASE_SSL=false

# ─── Integrations ─────────────────────────────────────────────────────────────
APOLLO_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=

# Optional: Tomba email-finder fallback when Apollo returns no email.
# Note: must use X-Tomba-Key / X-Tomba-Secret headers (not X-Tomain-*).
TOMBA_API_KEY=
TOMBA_API_SECRET=
